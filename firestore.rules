rules_version = '2';

// Companion / mHealth RCT — Firestore security rules.
//
// Threat model: the only writer of user data is the authenticated user
// themselves; the global arm-balancing counter is the only doc outside
// the per-user scope. Server-side admin reads happen via service accounts
// which bypass these rules.
//
// Collections this app uses:
//   users/{uid}                        -> profile (incl. arm, consent)
//   users/{uid}/events/{eventId}       -> analytics events
//   users/{uid}/memory/{moduleId}/entries/{id}  -> module summaries
//   users/{uid}/action_plans/{id}      -> M7 plans
//   users/{uid}/thought_records/{id}   -> M4 records
//   meta/arm_counter                   -> global A/B balance counter

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: signed-in.
    function isAuthed() {
      return request.auth != null;
    }

    // Helper: this request is from the owner of {uid}.
    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // The user's own document and every subcollection underneath it.
    // {document=**} matches all descendants so we don't have to repeat
    // the per-subcollection rule for events / memory / action_plans /
    // thought_records.
    match /users/{uid}/{document=**} {
      allow read, write: if isOwner(uid);
    }

    // RCT arm balance counter. Any signed-in user can read it (the
    // assigner needs to read counts to pick the under-represented arm)
    // and may write it ONLY as part of the increment-by-one transaction
    // the assigner performs. We enforce that by:
    //   1. requiring auth
    //   2. requiring the new total to be exactly old total + 1 (or
    //      starting at 1 if the doc didn't exist yet)
    //   3. requiring only the aCount / bCount / updatedAt fields to
    //      change.
    match /meta/arm_counter {
      allow read: if isAuthed();

      function priorA() {
        return resource == null ? 0 : (resource.data.aCount == null ? 0 : resource.data.aCount);
      }
      function priorB() {
        return resource == null ? 0 : (resource.data.bCount == null ? 0 : resource.data.bCount);
      }
      function nextA() {
        return request.resource.data.aCount;
      }
      function nextB() {
        return request.resource.data.bCount;
      }

      allow create, update: if isAuthed()
        && (
             // exactly one of A or B incremented by exactly 1, the other unchanged
             (nextA() == priorA() + 1 && nextB() == priorB())
          || (nextB() == priorB() + 1 && nextA() == priorA())
        );
    }

    // Everything else is denied by default.
  }
}
