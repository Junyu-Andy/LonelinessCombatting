rules_version = '2';

// Companion / mHealth RCT — Firestore security rules.
//
// Threat model: the only writer of user data is the authenticated user
// themselves; the global arm-balancing counter is the only doc outside
// the per-user scope. Server-side admin reads happen via service accounts
// which bypass these rules.
//
// Collections this app uses (existing + Sprint 1 additions):
//   users/{uid}                                  -> profile (incl. arm, consent,
//                                                   close_contacts, interests,
//                                                   firstIntroSeen, per-agent
//                                                   transcript flags)
//   users/{uid}/events/{eventId}                 -> analytics events
//   users/{uid}/memory/{moduleId}/entries/{id}   -> legacy module summaries
//   users/{uid}/action_plans/{id}                -> M7 plans
//   users/{uid}/thought_records/{id}             -> legacy M4 records
//   users/{uid}/m3_reminiscence/...              -> M3 sessions
//   users/{uid}/agent_contexts/{agent_id}        -> per-agent context (Dev Req §4.2)
//   users/{uid}/shared_context/current           -> cross-agent shared state
//   meta/arm_counter                             -> A/B balance counter

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // ============================================================
    // The owner reads/writes anything under their own user doc.
    // ============================================================
    // The {document=**} wildcard matches the profile doc and every
    // subcollection / sub-subcollection underneath it (events, memory,
    // action_plans, thought_records, m3_reminiscence, agent_contexts,
    // shared_context). The per-agent isolation specified in Dev Req §4.3
    // is enforced at the service layer (each Service addresses only its
    // own namespace) and audited via parity tests; per-field write
    // restrictions are out of scope for these client-facing rules
    // because the threat model is "the owner is the only writer of
    // their own data", not "different parts of the owner's client are
    // mutually distrustful".
    match /users/{uid}/{document=**} {
      allow read, write: if isOwner(uid);
    }

    // ============================================================
    // RCT arm balance counter.
    // ============================================================
    match /meta/arm_counter {
      allow read: if isAuthed();

      function priorA() {
        return resource == null ? 0 : (resource.data.aCount == null ? 0 : resource.data.aCount);
      }
      function priorB() {
        return resource == null ? 0 : (resource.data.bCount == null ? 0 : resource.data.bCount);
      }
      function nextA() {
        return request.resource.data.aCount;
      }
      function nextB() {
        return request.resource.data.bCount;
      }

      allow create, update: if isAuthed()
        && (
             (nextA() == priorA() + 1 && nextB() == priorB())
          || (nextB() == priorB() + 1 && nextA() == priorA())
        );
    }

    // Everything else is denied by default.
  }
}
